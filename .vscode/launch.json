{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug find_package example (macOS)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/vscode-debug/bhcpphptoolkit_vscode_example",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build VSCode Debug Example",
            "MIMode": "lldb",
            "miDebuggerPath": "/Applications/Xcode.app/Contents/Developer/usr/bin/lldb",
            "externalConsole": false,
            "stopAtEntry": false,
